{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/(.+)\\.(png|webp|jpg|jpeg|gif|svg|ico|avif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/crm-kommo",
      "destination": "/crm",
      "permanent": true
    },
    {
      "source": "/marketingmedico",
      "destination": "https://medicos.svicompany.com.br/",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "https://medicos.svicompany.com.br/blog",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "https://medicos.svicompany.com.br/blog/:path*",
      "permanent": true
    }
  ]
}
